{
  "name": "storycrafter-3",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,server -c cyan,magenta \"vite\" \"npm run dev --prefix server\"",
    "build": "tsc -b && vite build && npm run build --prefix server",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "start": "npm run start --prefix server"
  },
  "dependencies": {
    "diff": "^5.2.0",
    "openai": "^4.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "eslint": "^9.5.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  }
}
